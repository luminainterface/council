{
  "id": null,
  "title": "🌀 Spiral Health",
  "tags": ["spiral", "health", "monitoring"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "System Overview",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 4},
      "targets": [
        {"expr": "swarm_health_score", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Agent Performance",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "swarm_agent_performance", "refId": "B"}
      ]
    },
    {
      "id": 3,
      "title": "Cost Tracking",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 6},
      "targets": [
        {"expr": "cost_usd_total", "refId": "C"}
      ]
    },
    {
      "id": 4,
      "title": "Pattern Mining Status",
      "type": "stat",
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 6},
      "targets": [
        {"expr": "pattern_miner_lag_seconds", "refId": "D"}
      ]
    },
    {
      "id": 5,
      "title": "Kill-Switch Status",
      "type": "stat",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 6},
      "targets": [
        {"expr": "killswitch_state", "refId": "E"}
      ]
    },
    {
      "id": 6,
      "title": "Semantic Drift Score",
      "type": "heatmap",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "targets": [
        {"expr": "semantic_drift_score", "refId": "A"}
      ],
      "legend": {"show": false},
      "tooltip": {"show": true, "showHistogram": true}
    },
    {
      "id": 7,
      "title": "Reward Row Ratio",
      "type": "stat",
      "gridPos": {"x": 12, "y": 20, "w": 6, "h": 4},
      "sparkline": {"show": true},
      "targets": [
        {"expr": "reward_row_ratio", "refId": "B"}
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {"color": "red", "value": 0.0},
          {"color": "green", "value": 0.7}
        ]
      }
    },
    {
      "id": 8,
      "title": "Hold-out Success Ratio",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 24, "w": 6, "h": 4},
      "targets": [
        {"expr": "holdout_success_ratio", "refId": "C"}
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "5s",
  "version": 1
} 