# ── Autonomous Software Spiral v2.7.0 Environment Configuration ──

# API Keys (required)
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GPU Configuration
SWARM_GPU_PROFILE=rtx_4070
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:128

# Budget Controls
SWARM_BUDGET_DAILY_USD=0.10
SWARM_CONFIDENCE_GATE=0.60
SWARM_COST_TRACKING_ENABLED=true

# Spiral Features
SWARM_PATTERN_MINING_ENABLED=true
SWARM_CACHE_ENABLED=true
SWARM_NIGHTLY_DISTILLATION=true

# Redis Configuration
REDIS_URL=redis://redis:6379/0
CACHE_REDIS_URL=redis://redis:6379/1
PATTERN_REDIS_URL=redis://redis:6379/3

# Pattern Mining Settings
PATTERN_MINING_INTERVAL=21600  # 6 hours in seconds
MIN_CLUSTER_SIZE=3
MIN_CONFIDENCE=0.7

# Training Configuration
LORA_RANK=16
LORA_ALPHA=32
MAX_TRAINING_TIME_MINUTES=120
TRAINING_BUDGET_USD=0.05

# Monitoring
PROMETHEUS_RETENTION_DAYS=30
GRAFANA_ADMIN_PASSWORD=swarm_admin_2024

# Registry Configuration (for CI/CD)
REGISTRY=registry.example.com
VERSION=v2.7.0-spiral 